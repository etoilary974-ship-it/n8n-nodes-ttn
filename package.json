{
  "name": "n8n-nodes-ttn",
  "version": "0.1.0",
  "description": "n8n community node for The Things Network (TTN)",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "ttn",
    "the-things-network",
    "lorawan"
  ],
  "license": "MIT",
  "homepage": "https://n8n.io",
  "author": {
    "name": "Test",
    "email": "test@example.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/etoilary974-ship-it/TTN_Node.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "node ./scripts/build-package.cjs",
    "deploy": "node ./scripts/deploy.cjs",
    "build:watch": "tsc --watch"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/ttnApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/ttn_node/ttn.node.js",
      "dist/nodes/ttn_node/ttnTrigger.node.js",
      "dist/nodes/ttn_node/ttnDownlink.node.js",
      "dist/nodes/ttn_node/ttnUplinkTrigger.node.js"
    ]
  },
  "dependencies": {
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "fast-glob": "3.2.12",
    "n8n-workflow": "^1.17.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
